{
  "name": "lumina-social-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade AI-ready creator-first social media platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=@lumina/api",
    "dev:web": "npm run dev --workspace=@lumina/web",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build --workspace=@lumina/api",
    "build:web": "npm run build --workspace=@lumina/web",
    "start": "npm run start --workspaces --if-present",
    "db:generate": "npm run generate --workspace=@lumina/database",
    "db:migrate": "npm run migrate --workspace=@lumina/database",
    "db:push": "npm run push --workspace=@lumina/database",
    "db:studio": "npm run studio --workspace=@lumina/database",
    "db:seed": "npm run seed --workspace=@lumina/database",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=@lumina/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.9.0"
}